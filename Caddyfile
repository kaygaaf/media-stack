# Caddyfile for media stack reverse proxy
# Set these env vars in your deployment environment (e.g., Coolify)

{$JELLYFIN_DOMAIN} {
    reverse_proxy localhost:8096
}

{$SONARR_DOMAIN} {
    reverse_proxy localhost:8989
}

